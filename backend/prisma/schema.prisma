generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  matricula String   @unique
  email     String   @unique
  password  String
  turma     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlacklistedToken {
  id        String   @id @default(uuid())
  token     String   @unique
  createdAt DateTime @default(now())
}
