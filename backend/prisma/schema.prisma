generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  matricula String   @unique
  email     String   @unique
  password  String
  turma     String
  avatarUrl  String?

  emailVerified   Boolean  @default(false)
  emailCode       String?
  emailCodeExpiry DateTime?

  twoFactorSecret  String?
  twoFactorEnabled Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  scans           Scan[]
  points          UserPoints?
  missionProgress UserMissionProgress[]
}

model BlacklistedToken {
  id        String   @id @default(uuid())
  token     String   @unique
  createdAt DateTime @default(now())
}

model Scan {
  id        String   @id @default(uuid())
  userId    String
  category  String
  points    Int
  imageUrl  String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

model UserPoints {
  id         String   @id @default(uuid())
  userId     String   @unique
  total      Int      @default(0)
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id])
}

model DailyMission {
  id          String   @id @default(uuid())
  title       String
  description String
  type        String                           // "scan_count" | "scan_category"
  target      Int
  category    String?                          // só para scan_category: "plastico", "papel", etc
  reward      Int
  createdAt   DateTime @default(now())

  progress    UserMissionProgress[]
}

model UserMissionProgress {
  id            String    @id @default(uuid())
  userId        String
  missionId     String
  progress      Int       @default(0)
  completed     Boolean   @default(false)
  rewardClaimed Boolean   @default(false)
  assignedAt    DateTime  @default(now())
  completedAt   DateTime?

  user    User         @relation(fields: [userId], references: [id])
  mission DailyMission @relation(fields: [missionId], references: [id])

  @@unique([userId, assignedAt])
}
