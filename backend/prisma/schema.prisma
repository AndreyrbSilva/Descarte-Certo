generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  matricula String   @unique
  email     String   @unique
  password  String
  turma     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  scans      Scan[]
  points     UserPoints?
}

model BlacklistedToken {
  id        String   @id @default(uuid())
  token     String   @unique
  createdAt DateTime @default(now())
}

model Scan {
  id        String   @id @default(uuid())
  userId    String
  category  String
  points    Int
  imageUrl  String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

model UserPoints {
  id         String   @id @default(uuid())
  userId     String   @unique
  total      Int      @default(0)
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id])
}
